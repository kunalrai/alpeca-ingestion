model us_stocks {
  symbol                   String    @id
  description              String?
  currency                 String?
  mic                      String?
  type                     String?
  is_active                Boolean?  @default(true)
  listed_at                DateTime? @default(now()) @db.Timestamptz(6)
  updated_at               DateTime? @default(now()) @db.Timestamptz(6)
  last_fundamentals_update DateTime? @db.Timestamptz(6)

  @@schema("master")
}
