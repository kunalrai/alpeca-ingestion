generator client {
  provider        = "prisma-client"
  output          = "../generated/prisma"
  previewFeatures = []
}

datasource db {
  provider = "postgresql"
  schemas  = ["master"]
}

model ingest_watermark {
  job            String   @id
  last_timestamp DateTime @db.Timestamptz(6)
  updated_at     DateTime @default(now()) @db.Timestamptz(6)

  @@schema("master")
}

/// The underlying table does not contain a valid unique identifier and can therefore currently not be handled by Prisma Client.
model ohlc {
  symbol    String
  timestamp DateTime @db.Timestamptz(6)
  open      Float?
  high      Float?
  low       Float?
  close     Float?
  volume    Float?

  @@index([timestamp(sort: Desc)])
  @@ignore
  @@schema("master")
}

/// The underlying table does not contain a valid unique identifier and can therefore currently not be handled by Prisma Client.
model ohlc_premarket {
  symbol    String
  timestamp DateTime @db.Timestamptz(6)
  open      Float?
  high      Float?
  low       Float?
  close     Float?
  volume    Float?

  @@index([timestamp(sort: Desc)])
  @@ignore
  @@schema("master")
}

model safe_bet {
  symbol                     String
  name                       String?
  previous_close             Decimal? @db.Decimal
  open_price                 Decimal? @db.Decimal
  current_price              Decimal? @db.Decimal
  pct_change_from_prev_close Decimal? @db.Decimal
  pct_change_from_open       Decimal? @db.Decimal
  query_type                 String   @default("live")
  captured_at                DateTime @default(now()) @db.Timestamptz(6)

  @@id([symbol, query_type])
  @@schema("master")
}

